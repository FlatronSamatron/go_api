# Объявляем цели, которые не являются файлами
.PHONY: build

# Сборка бинарника из точки входа ./cmd/apiserver
build:
	go build -v ./cmd/apiserver

# Цель по умолчанию при вызове make без аргументов
.DEFAULT_GOAL := build

# -----------------------------------------------------------
# Шпаргалка по Makefile
# -----------------------------------------------------------
# .PHONY      — указываем, что цель НЕ является файлом на диске.
#               Без этого make будет искать файл с именем "build"
#               и пропустит выполнение, если такой файл уже есть.
#
# build:      — имя цели (задачи). Запускается командой: make build
#
# go build …  — сама shell-команда, которая выполняется при вызове цели.
#               ВАЖНО: перед командой должен стоять TAB, не пробелы.
#
# .DEFAULT_GOAL — задаёт цель по умолчанию. Если просто написать make
#               (без аргументов), выполнится именно она.
# -----------------------------------------------------------